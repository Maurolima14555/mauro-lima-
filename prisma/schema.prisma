// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  }

  datasource db {
    provider = "postgresql"
      url      = env("DATABASE_URL")
      }

      model User {
        id            String    @id @default(cuid())
          name          String?
            email         String    @unique
              emailVerified DateTime?
                image         String?
                  createdAt     DateTime  @default(now())
                    updatedAt     DateTime  @updatedAt

                      projects      Project[]
                        subscription  Subscription?

                          @@map("users")
                          }

                          model Project {
                            id          String   @id @default(cuid())
                              userId      String
                                title       String
                                  description String?
                                    type        ProjectType @default(VIDEO)
                                      status      ProjectStatus @default(DRAFT)
                                        createdAt   DateTime @default(now())
                                          updatedAt   DateTime @updatedAt

                                            user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
                                              videos      Video[]

                                                @@map("projects")
                                                }

                                                model Video {
                                                  id          String   @id @default(cuid())
                                                    projectId   String
                                                      title       String
                                                        script      String?  @db.Text
                                                          audioUrl    String?
                                                            videoUrl    String?
                                                              thumbnailUrl String?
                                                                duration    Int?
                                                                  status      VideoStatus @default(PENDING)
                                                                    metadata    Json?    @default("{}")
                                                                      createdAt   DateTime @default(now())
                                                                        updatedAt   DateTime @updatedAt

                                                                          project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
                                                                            scenes      Scene[]

                                                                              @@map("videos")
                                                                              }

                                                                              model Scene {
                                                                                id          String   @id @default(cuid())
                                                                                  videoId     String
                                                                                    order       Int
                                                                                      text        String   @db.Text
                                                                                        imageUrl    String?
                                                                                          audioUrl    String?
                                                                                            duration    Int?
                                                                                              createdAt   DateTime @default(now())

                                                                                                video       Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

                                                                                                  @@map("scenes")
                                                                                                  }

                                                                                                  model Subscription {
                                                                                                    id                String   @id @default(cuid())
                                                                                                      userId            String   @unique
                                                                                                        plan              PlanType @default(FREE)
                                                                                                          status            SubStatus @default(ACTIVE)
                                                                                                            stripeCustomerId  String?
                                                                                                              stripeSubId       String?
                                                                                                                currentPeriodEnd  DateTime?
                                                                                                                  createdAt         DateTime @default(now())
                                                                                                                    updatedAt         DateTime @updatedAt
                                                                                                                    
                                                                                                                      user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
                                                                                                                      
                                                                                                                        @@map("subscriptions")
                                                                                                                        }
                                                                                                                        
                                                                                                                        enum ProjectType {
                                                                                                                          VIDEO
                                                                                                                            SHORT
                                                                                                                              TRANSLATION
                                                                                                                              }
                                                                                                                              
                                                                                                                              enum ProjectStatus {
                                                                                                                                DRAFT
                                                                                                                                  PROCESSING
                                                                                                                                    COMPLETED
                                                                                                                                      FAILED
                                                                                                                                      }
                                                                                                                                      
                                                                                                                                      enum VideoStatus {
                                                                                                                                        PENDING
                                                                                                                                          GENERATING_SCRIPT
                                                                                                                                            GENERATING_AUDIO
                                                                                                                                              GENERATING_IMAGES
                                                                                                                                                RENDERING
                                                                                                                                                  COMPLETED
                                                                                                                                                    FAILED
                                                                                                                                                    }
                                                                                                                                                    
                                                                                                                                                    enum PlanType {
                                                                                                                                                      FREE
                                                                                                                                                        STARTER
                                                                                                                                                          PRO
                                                                                                                                                            ENTERPRISE
                                                                                                                                                            }
                                                                                                                                                            
                                                                                                                                                            enum SubStatus {
                                                                                                                                                              ACTIVE
                                                                                                                                                                CANCELED
                                                                                                                                                                  PAST_DUE
                                                                                                                                                                    TRIALING
                                                                                                                                                                    }
